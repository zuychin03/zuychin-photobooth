# ─── Supabase ─────────────────────────────────────────────
# Powers WebRTC signaling (Realtime) and, once the schema in supabase/ is
# installed, accounts + the shared album + relays + photo dates.
# Without these, the booth still works; account features stay hidden.
# Full walkthrough: SUPABASE_SETUP.md
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only, bypasses RLS. Used by the reminder and retention cron routes.
# Needed only for photo-date reminders and the weekly purge.
SUPABASE_SERVICE_ROLE_KEY=

# Only for sharing one login across sibling apps served under one parent
# domain (e.g. .example.com for booth.example.com + gallery.example.com):
# set to that parent with a leading dot, identically in every app.
# Leave BLANK on localhost or a standalone deploy.
NEXT_PUBLIC_COOKIE_DOMAIN=

# ─── Cloudinary (archive kept strips, optional) ───────────
# Bookmarking a strip uploads it here (private, authenticated delivery) so
# the weekly purge can drop the Supabase Storage copy while the strip lives
# on. Without these, bookmarking still exempts a strip from the purge; it
# just stays in Supabase Storage instead.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── TURN (cross-network rooms) ───────────────────────────
# URL MUST start with turn: or turns:. A bare host:port is silently ignored.
# Comma-separate multiple transports (UDP, TCP, TLS) for restrictive networks.
# e.g. turn:relay.example.com:3478,turn:relay.example.com:3478?transport=tcp
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

# ─── Photo-date reminders (optional) ──────────────────────
# Resend API key (https://resend.com) for sending reminder emails.
RESEND_API_KEY=
# Verified sender. Defaults to Resend's onboarding sender for testing.
REMINDER_FROM=Zuychin Photobooth <onboarding@resend.dev>
# Shared secret the cron scheduler sends as `Authorization: Bearer <secret>`
# (or ?secret=) so only it can trigger the reminder and retention routes.
CRON_SECRET=
