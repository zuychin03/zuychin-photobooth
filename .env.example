# Supabase Realtime is used only as the WebRTC signaling layer (no data stored).
# Without these, rooms fall back to BroadcastChannel: two tabs in the same
# browser can pair, but not two devices.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# TURN relay for networks where direct P2P fails (needed for reliable
# cross-country connections). Free tier: https://www.metered.ca/stun-turn
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
