# ─── Supabase ─────────────────────────────────────────────
# Same project as zuychin-gallery. Powers WebRTC signaling (Realtime) and,
# if the schema is installed, accounts + timeline + relays + photo dates.
# Without these, the booth still works; account features stay hidden.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only, bypasses RLS. Used by the reminder cron to read couple emails.
# Needed only for scheduled photo-date reminders.
SUPABASE_SERVICE_ROLE_KEY=

# Shares one login with Zuychin Gallery (SSO). Set to the shared parent domain
# with a leading dot when both apps are served under it (e.g. .zuychin.me for
# booth.zuychin.me + gallery.zuychin.me). Leave BLANK on localhost or a
# single-domain deploy. Must match Gallery's value exactly.
NEXT_PUBLIC_COOKIE_DOMAIN=

# ─── Cloudinary (keep strips in Zuychin Gallery) ──────────
# SAME account as zuychin-gallery. Bookmarking a strip pushes it here so it
# has a permanent home in Gallery's Photobooth view. Without these, bookmarking
# still exempts a strip from the weekly purge; it just is not pushed to Gallery.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── TURN (cross-network rooms) ───────────────────────────
# URL MUST start with turn: or turns:. A bare host:port is silently ignored.
# Comma-separate multiple transports (UDP, TCP, TLS) for restrictive networks.
# e.g. turn:relay.example.com:3478,turn:relay.example.com:3478?transport=tcp
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

# ─── Photo-date reminders (optional) ──────────────────────
# Resend API key (https://resend.com) for sending reminder emails.
RESEND_API_KEY=
# Verified sender. Defaults to Resend's onboarding sender for testing.
REMINDER_FROM=Zuychin Photobooth <onboarding@resend.dev>
# Shared secret the cron scheduler sends as `Authorization: Bearer <secret>`
# (or ?secret=) so only it can trigger sends.
CRON_SECRET=
